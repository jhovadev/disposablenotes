---
import Layout from "../layout/layout.astro"
---

<Layout>
  <div class="fixed top-0 left-0 w-full h-screen z-[-1] overflow-hidden bg-[#0A0A0A]">
    <div class="masonry-grid columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4 p-4 opacity-30 min-h-[200vh]">
      <div class="masonry-item rounded-2xl overflow-hidden shadow-lg"><img src="https://placehold.co/400x600/1A1A1A/333333?text=Nota" class="w-full h-auto" alt=""></div>
      <div class="masonry-item rounded-2xl overflow-hidden shadow-lg"><img src="https://placehold.co/400x300/1A1A1A/333333?text=Nota" class="w-full h-auto" alt=""></div>
      <div class="masonry-item rounded-2xl overflow-hidden shadow-lg"><img src="https://placehold.co/400x800/1A1A1A/333333?text=Nota" class="w-full h-auto" alt=""></div>
      <div class="masonry-item rounded-2xl overflow-hidden shadow-lg"><img src="https://placehold.co/400x400/1A1A1A/333333?text=Nota" class="w-full h-auto" alt=""></div>
      <div class="masonry-item rounded-2xl overflow-hidden shadow-lg"><img src="https://placehold.co/400x500/1A1A1A/333333?text=Nota" class="w-full h-auto" alt=""></div>
      <div class="masonry-item rounded-2xl overflow-hidden shadow-lg"><img src="https://placehold.co/400x700/1A1A1A/333333?text=Nota" class="w-full h-auto" alt=""></div>
      <div class="masonry-item rounded-2xl overflow-hidden shadow-lg"><img src="https://placehold.co/400x350/1A1A1A/333333?text=Nota" class="w-full h-auto" alt=""></div>
      <div class="masonry-item rounded-2xl overflow-hidden shadow-lg"><img src="https://placehold.co/400x450/1A1A1A/333333?text=Nota" class="w-full h-auto" alt=""></div>
      <div class="masonry-item rounded-2xl overflow-hidden shadow-lg"><img src="https://placehold.co/400x600/1A1A1A/333333?text=Nota" class="w-full h-auto" alt=""></div>
      <div class="masonry-item rounded-2xl overflow-hidden shadow-lg"><img src="https://placehold.co/400x300/1A1A1A/333333?text=Nota" class="w-full h-auto" alt=""></div>
      <div class="masonry-item rounded-2xl overflow-hidden shadow-lg"><img src="https://placehold.co/400x800/1A1A1A/333333?text=Nota" class="w-full h-auto" alt=""></div>
    </div>
    <div class="absolute bottom-0 left-0 w-full h-64 bg-gradient-to-t from-[#0A0A0A] to-transparent pointer-events-none"></div>
  </div>

  <main class="w-full flex flex-col relative z-10">
    
    <section class="min-h-screen flex flex-col items-center justify-center p-6">
      <div class="main-card group relative flex flex-col items-center max-w-sm p-8 transition-all duration-500">
        <h1 class="text-4xl font-semibold tracking-tight text-white mb-2">dn.</h1>
        <div class="relative w-full aspect-[4/3] mb-8 mt-6 flex items-center justify-center [perspective:1200px] [transform-style:preserve-3d]">
          <img class="absolute w-4/5 h-auto object-cover rounded-2xl shadow-sm transition-all duration-700 ease-out opacity-20 [transform:rotateX(20deg)_rotateY(-25deg)_rotateZ(5deg)_translate3d(30px,30px,-100px)] group-hover:[transform:rotateX(15deg)_rotateY(-20deg)_rotateZ(5deg)_translate3d(60px,60px,-120px)]" src="./disposable_note.png" alt="Nota de fondo">
          <img class="absolute w-4/5 h-auto object-cover rounded-2xl shadow-md transition-all duration-700 ease-out opacity-50 [transform:rotateX(20deg)_rotateY(-25deg)_rotateZ(5deg)_translate3d(15px,15px,-50px)] group-hover:[transform:rotateX(15deg)_rotateY(-20deg)_rotateZ(5deg)_translate3d(30px,30px,-60px)]" src="./disposable_note.png" alt="Nota central">
          <img class="absolute h-auto object-cover rounded-2xl shadow-[0_20px_40px_rgba(0,0,0,0.8)] transition-all duration-700 ease-out [transform:rotateX(20deg)_rotateY(-25deg)_rotateZ(5deg)_translate3d(0,0,0)] group-hover:[transform:rotateX(15deg)_rotateY(-20deg)_rotateZ(5deg)_translate3d(0,0,0)_scale(1.05)] border border-white/10" src="./disposable_note.png" alt="Preview principal">
        </div>
        <p class="text-center text-gray-400 leading-relaxed mb-8">
          Una herramienta para aquel que tiene muchas ideas, no sabe dónde guardarlas y le preocupa perderlas.
        </p>
        <a href="https://github.com/jhovadev/disposablenotes" class="text-neutral-200">github</a>
      </div>
    </section>

    <section class="scroll-section min-h-screen flex flex-col items-center justify-center p-6 max-w-5xl mx-auto w-full">
      <h2 class="text-3xl md:text-5xl font-semibold tracking-tight text-white mb-16 text-center">Rápido. Simple. Tuyo.</h2>
      
      <div class="flex flex-col gap-20 w-full">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div class="space-y-4 order-2 md:order-1">
            <h3 class="text-2xl font-medium text-white">Atajos de teclado</h3>
            <p class="text-gray-400 text-lg leading-relaxed">Navega, crea y organiza sin quitar las manos del teclado. Pensado para la máxima eficiencia del desarrollador.</p>
          </div>
          <div class="relative group [perspective:1000px] order-1 md:order-2">
            <img class="w-full h-auto object-cover rounded-2xl shadow-[0_20px_40px_rgba(0,0,0,0.5)] border border-white/10 transition-transform duration-700 ease-out group-hover:[transform:rotateY(-5deg)_rotateX(5deg)]" src="./disposable_note_help.png" loading="lazy" alt="Vista de atajos de teclado">
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div class="relative group [perspective:1000px] order-1">
            <img class="w-full h-auto object-cover rounded-2xl shadow-[0_20px_40px_rgba(0,0,0,0.5)] border border-white/10 transition-transform duration-700 ease-out group-hover:[transform:rotateY(5deg)_rotateX(5deg)]" src="./disposable_note_list.png" loading="lazy" alt="Vista de notas locales">
          </div>
          <div class="space-y-4 order-2">
            <h3 class="text-2xl font-medium text-white">Local-first</h3>
            <p class="text-gray-400 text-lg leading-relaxed">Tus notas viven en tu dispositivo primero. Privacidad total y velocidad instantánea sin depender de servidores ni conexiones inestables.</p>
          </div>
        </div>

      </div>
    </section>

